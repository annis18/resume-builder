# Server
PORT=5000
NODE_ENV=development

# Database (MongoDB Atlas or local connection string)
MONGO_URI=your_mongodb_connection_string_here

# Auth
JWT_SECRET=replace_with_a_long_random_string

# Frontend origin (for CORS) — update once the React app is running
CLIENT_URL=http://localhost:5173

# AI Integration — get a key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional. Defaults to gemini-3.5-flash if unset. For a cheaper/faster
# (slightly less capable) option for this simple task, try gemini-3.1-flash-lite
GEMINI_MODEL=gemini-3.5-flash
